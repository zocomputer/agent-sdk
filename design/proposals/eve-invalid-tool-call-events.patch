diff --git a/packages/eve/src/harness/invalid-actions.ts b/packages/eve/src/harness/invalid-actions.ts
new file mode 100644
index 0000000..280017b
--- /dev/null
+++ b/packages/eve/src/harness/invalid-actions.ts
@@ -0,0 +1,68 @@
+import type { ToolSet, TypedToolCall } from "ai";
+import { NoSuchToolError } from "ai";
+
+import type { ActionInvalidReason } from "#protocol/message.js";
+import { createActionInvalidEvent } from "#protocol/message.js";
+import { toError } from "#shared/errors.js";
+import type { JsonValue } from "#shared/json.js";
+import { parseJsonValue } from "#shared/json.js";
+import type { HarnessEmissionState } from "#harness/emission.js";
+import type { HarnessEmitFn } from "#harness/types.js";
+
+/**
+ * Emits one `action.invalid` event for a model tool call that failed
+ * validation before execution (no matching tool, or input that failed the
+ * tool's input schema).
+ *
+ * Shared by the streaming pass (`emitStreamContent`) and the post-step pass
+ * (`emitStepActions`); `emittedInvalidCallIds` dedupes across them.
+ * Deliberately ignores `excludedActionToolNames`: that exclusion governs how
+ * *valid* calls are projected (e.g. HITL tools get `input.requested` instead
+ * of `actions.requested`), while an invalid call has no other lifecycle event
+ * and should stay observable for every tool.
+ */
+export async function emitInvalidToolCall(
+  emitFn: HarnessEmitFn,
+  state: HarnessEmissionState,
+  toolCall: TypedToolCall<ToolSet>,
+  emittedInvalidCallIds: Set<string>,
+): Promise<void> {
+  if (emittedInvalidCallIds.has(toolCall.toolCallId)) {
+    return;
+  }
+  emittedInvalidCallIds.add(toolCall.toolCallId);
+  const reason: ActionInvalidReason = NoSuchToolError.isInstance(toolCall.error)
+    ? "no-such-tool"
+    : "invalid-input";
+  await emitFn(
+    createActionInvalidEvent({
+      callId: toolCall.toolCallId,
+      errorText: toError(toolCall.error).message,
+      input: normalizeInvalidCallInput(toolCall.input),
+      reason,
+      sequence: state.sequence,
+      stepIndex: state.stepIndex,
+      toolName: toolCall.toolName,
+      turnId: state.turnId,
+    }),
+  );
+}
+
+/**
+ * Coerces an invalid tool call's raw input for the `action.invalid` payload.
+ *
+ * The AI SDK leaves the input as the raw string when the JSON was unparsable
+ * and as the parsed value otherwise, so this normally succeeds; anything
+ * non-JSON-serializable is dropped rather than allowed to fail the step over
+ * a diagnostic event (`errorText` still describes the failure).
+ */
+function normalizeInvalidCallInput(input: unknown): JsonValue | undefined {
+  if (input === undefined) {
+    return undefined;
+  }
+  try {
+    return parseJsonValue(input);
+  } catch {
+    return undefined;
+  }
+}
