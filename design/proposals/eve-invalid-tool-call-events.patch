@@ -232,6 +234,16 @@ export async function emitStepActions(
   const isExcluded = (toolCallId: string, toolName: string): boolean =>
     excludedCallIds.has(toolCallId) || options.excludedActionToolNames.has(toolName);
 
+  // Invalid calls never execute, so surface each one on `action.invalid`.
+  // The streaming pass already emitted calls whose final chunk carried the
+  // `invalid` flag; this pass catches the ones it couldn't see (the SDK can
+  // finalize a call as invalid only in the step result) — the shared set
+  // dedupes across the two passes.
+  const emittedInvalidCallIds = new Set<string>(options.emittedInvalidCallIds);
+  for (const toolCall of (step.toolCalls as TypedToolCall<ToolSet>[]).filter(isInvalidToolCall)) {
+    await emitInvalidToolCall(emitFn, state, toolCall, emittedInvalidCallIds);
+  }
+
   // Streamed calls already emitted their request. The loop below emits their
   // result.
   const actions = (step.toolCalls as TypedToolCall<ToolSet>[])
