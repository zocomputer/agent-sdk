@@ -50,8 +50,86 @@ const HYDRATE_IMAGE_INLINE_MAX_BYTES = 3 * 1024 * 1024;
  */
 const HYDRATE_PDF_INLINE_MAX_BYTES = 20 * 1024 * 1024;
 
+/**
+ * Upper bound, in bytes, on video/audio payloads that hydrate as inline
+ * bytes for models that accept them natively. Matches the Gemini API's
+ * inline-data request budget.
+ */
+const HYDRATE_MEDIA_INLINE_MAX_BYTES = 20 * 1024 * 1024;
+
 const PDF_MEDIA_TYPE = "application/pdf";
 const IMAGE_MEDIA_TYPE_PREFIX = "image/";
+const VIDEO_MEDIA_TYPE_PREFIX = "video/";
+const AUDIO_MEDIA_TYPE_PREFIX = "audio/";
+
+/**
+ * Media kinds beyond images and PDFs that the resolved turn model accepts
+ * as inline bytes. Detected per model family by
+ * {@link detectModelMediaSupport}; the default is none, which preserves the
+ * image/PDF-only hydration behavior.
+ */
+export interface ModelMediaSupport {
+  /** `video/*` file parts hydrate as inline bytes. */
+  readonly video: boolean;
+  /** `audio/*` file parts hydrate as inline bytes. */
+  readonly audio: boolean;
+}
+
+const NO_EXTENDED_MEDIA_SUPPORT: ModelMediaSupport = Object.freeze({
+  video: false,
+  audio: false,
+});
+
+/**
+ * Detects which media kinds beyond images/PDFs the resolved model accepts
+ * as inline bytes, so hydration can widen its inline decision without ever
+ * sending a provider a part it would reject (a rejected part fails the
+ * whole model call — e.g. Anthropic's converter throws
+ * `UnsupportedFunctionalityError` on non-image/PDF media).
+ *
+ * Keyed by provider family, mirroring {@link detectPromptCachePath}'s
+ * approach: the AI SDK exposes no per-model inline-media introspection
+ * (`supportedUrls` covers URL passthrough only), so this encodes what is
+ * safe per family. Today that is the **google** family only (Gemini via
+ * `@ai-sdk/google`, Vertex, or the gateway): its converter turns any file
+ * part into `inlineData`, and every Gemini language model natively
+ * understands video and audio. OpenAI is deliberately excluded — its
+ * converter maps wav/mp3 to `input_audio`, but only the audio-preview /
+ * realtime model subset accepts those, so a family-level rule would fail
+ * calls on mainline models.
+ *
+ * Runs once per harness step on the already-resolved model.
+ */
+export function detectModelMediaSupport(model: LanguageModel | undefined): ModelMediaSupport {
+  if (model === undefined) {
+    return NO_EXTENDED_MEDIA_SUPPORT;
+  }
+  if (providerFamilyForModel(model) === "google") {
+    return { video: true, audio: true };
+  }
+  return NO_EXTENDED_MEDIA_SUPPORT;
+}
+
+/**
+ * Best-effort provider family for a resolved model. A bare string id is a
+ * gateway id (`"google/gemini-3-pro"`) whose creator segment names the
+ * family; a gateway model instance carries the same id in `modelId`; a
+ * direct provider instance names its family in the top-level `provider`
+ * segment (`"google.generative-ai"` → `"google"`). Unknown shapes return
+ * `""`, which maps to no extended media support.
+ */
+function providerFamilyForModel(model: LanguageModel): string {
+  if (typeof model === "string") {
+    return model.includes("/") ? model.split("/", 1)[0]!.toLowerCase() : "";
+  }
+  const provider = typeof model.provider === "string" ? model.provider.toLowerCase() : "";
+  const topLevelProvider = provider.split(".", 1)[0] ?? "";
+  if (topLevelProvider === "gateway") {
+    const modelId = typeof model.modelId === "string" ? model.modelId : "";
+    return modelId.includes("/") ? modelId.split("/", 1)[0]!.toLowerCase() : "";
+  }
+  return topLevelProvider;
+}
 
 /**
  * Writes inbound `FilePart` bytes into the sandbox and rewrites each
@@ -130,12 +208,15 @@ export async function stageAttachmentsToSandbox(
 /**
